# ==============================================================================
# My64 Village Connect - Comprehensive .gitignore
# ==============================================================================

# Python / Django
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python Virtual Environments
venv/
.venv/
env/
ENV/
backend/venv/
backend/env/
backend/ENV/
backend/.venv/

# Django specific
db.sqlite3
db.sqlite3-journal
*.log
local_settings.py
backend/staticfiles/
backend/media/
staticfiles/
media/

# Node / Frontend
# ------------------------------------------------------------------------------
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Frontend Build
dist/
frontend/dist/
.vite/
frontend/.vite/
.nuxt/
.next/
out/
.vercel

# Environment / Secret Files (Crucial for Security!)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
frontend/.env.local

# Keep .env_frontend only if explicitly desired, otherwise recommended to keep out
# .env_frontend

# OS & Editor files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
