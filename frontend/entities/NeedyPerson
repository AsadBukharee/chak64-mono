{
  "name": "NeedyPerson",
  "type": "object",
  "properties": {
    "team_id": {
      "type": "string",
      "description": "Reference to Team entity"
    },
    "full_name": {
      "type": "string",
      "description": "Full name of the needy person"
    },
    "address": {
      "type": "string",
      "description": "Address / house number"
    },
    "contact_number": {
      "type": "string",
      "description": "Contact phone number"
    },
    "family_size": {
      "type": "number",
      "description": "Number of family members"
    },
    "need_type": {
      "type": "string",
      "enum": [
        "food",
        "medical",
        "education",
        "financial",
        "housing",
        "other"
      ],
      "description": "Primary type of need"
    },
    "monthly_income": {
      "type": "number",
      "description": "Approximate monthly household income"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of needs"
    },
    "priority": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "default": "medium",
      "description": "Priority level for assistance"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "assisted",
        "resolved"
      ],
      "default": "active",
      "description": "Current assistance status"
    },
    "added_by": {
      "type": "string",
      "description": "Email of the team member who added this record"
    },
    "added_by_name": {
      "type": "string",
      "description": "Name of the team member who added this record"
    }
  },
  "required": [
    "team_id",
    "full_name",
    "need_type"
  ]
}